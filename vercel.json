{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/pages/Falcon%20AI", "destination": "/falcon", "permanent": true },
    { "source": "/pages/Falcon AI", "destination": "/falcon", "permanent": true },
    { "source": "/pages/Data%20Desk", "destination": "/data-desk", "permanent": true },
    { "source": "/pages/Data Desk", "destination": "/data-desk", "permanent": true },
    { "source": "/pages/Services", "destination": "/ai-services", "permanent": true },
    { "source": "/pages/Pricing", "destination": "/pricing", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    }
  ]
}
